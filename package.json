{
  "name": "@dylanmccavitt/skills",
  "version": "0.4.0",
  "description": "Install the Gepetto, Pinocchio, Jiminy, and Checkpoint orchestration skills for Codex.",
  "license": "MIT",
  "author": "Dylan McCavitt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dylanmccavitt/skills.git"
  },
  "homepage": "https://github.com/dylanmccavitt/skills#readme",
  "bugs": "https://github.com/dylanmccavitt/skills/issues",
  "type": "module",
  "bin": {
    "skills": "bin/install.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "checkpoint/SKILL.md",
    "checkpoint/agents/",
    "gepetto/",
    "hooks/hooks.json",
    "hooks/orchestration_events.py",
    "hooks/orchestration_graph.py",
    "hooks/orchestration_hook.py",
    "hooks/orchestration_state.py",
    "hooks/orchestration_watchdog.py",
    "jiminy/",
    "pinocchio/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.mjs && python3 -m unittest discover -s hooks -p 'test_*.py' && python3 hooks/orchestration_graph.py",
    "prepack": "npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "codex",
    "codex-skills",
    "orchestration"
  ]
}
