{
  "version": 1,
  "workflow": "gepetto-delivery",
  "initial_node": "research",
  "policies": {
    "max_review_fix_cycles": 3,
    "one_writer_per_leaf": true,
    "proof_bound_to_live_head": true,
    "inline_research": "single_leaf_keep",
    "packet_authoritative_when_head_matches": true,
    "context_addressing": {
      "algorithm": "sha256",
      "input": "exact_file_bytes",
      "digest_version": 1,
      "includes_arity": true,
      "reload": "digest_change_only",
      "survives_continuation": true
    },
    "registration": {
      "authority": "coordinator",
      "child_action": "verify",
      "conflicts": "reject"
    },
    "terminal_receipts": {
      "delivery": "task_final_result",
      "exactly_once": true,
      "separate_send": false,
      "jiminy_intermediate_notifications": true
    },
    "supervision": {
      "heartbeat_ttl_seconds": {"gepetto": 1800, "research": 900, "implementation": 2700, "review": 2700, "jiminy": 900},
      "max_lane_restarts": 2,
      "recycle_context_ratio": 0.8,
      "recycle_state_bytes": 131072,
      "recycle_after_events": 400,
      "pressure_ttl_seconds": 300,
      "event_count_role": "compatibility_fallback"
    }
  },
  "packet_types": [
    "RESEARCH_PACKET",
    "IMPLEMENTATION_PACKET",
    "REVIEW_PACKET",
    "JIMINY_READY",
    "JIMINY_PR_RESULT",
    "JIMINY_INTEGRATION_FAILED",
    "JIMINY_COMPLETE"
  ],
  "nodes": {
    "research": {"owner": "gepetto", "lane_role": "research"},
    "implementation": {"owner": "pinocchio", "lane_role": "implementation", "fanout": "approved_leaves"},
    "review": {"owner": "reviewer", "lane_role": "review", "fanout": "pull_requests"},
    "fixer": {"owner": "reviewer", "lane_role": "fixer", "serial_per_pull_request": true},
    "merge": {"owner": "jiminy", "lane_role": "jiminy", "dependency_ordered": true},
    "integration_verification": {"owner": "jiminy", "lane_role": "jiminy"},
    "blocked": {"owner": "gepetto", "resumable": true},
    "needs_decision": {"owner": "gepetto", "resumable": true},
    "cancelled": {"terminal": true},
    "complete": {"terminal": true}
  },
  "transitions": [
    {
      "id": "research-approved",
      "from": ["research"],
      "event": "RESEARCH_PACKET",
      "packet_type": "RESEARCH_PACKET",
      "to": "implementation",
      "all": [
        {"path": "packet.artifact.status", "equals": "persisted"},
        {"path": "packet.delivery_issue_urls", "non_empty": true},
        {"path": "persisted.validated_delivery_spec_digest", "content_ref": true}
      ]
    },
    {
      "id": "implementation-proved",
      "from": ["implementation"],
      "event": "IMPLEMENTATION_PACKET",
      "packet_type": "IMPLEMENTATION_PACKET",
      "to": "review",
      "all": [
        {"path": "packet.artifact.status", "equals": "persisted"},
        {"path": "packet.pr_head_sha", "equals_path": "live.pr_head_sha"}
      ]
    },
    {
      "id": "review-found-issues",
      "from": ["review"],
      "event": "ACTIONABLE_FINDINGS",
      "to": "fixer",
      "all": [
        {"path": "review_fix_cycles", "less_than_policy": "max_review_fix_cycles"}
      ],
      "increment": {"path": "review_fix_cycles", "by": 1}
    },
    {
      "id": "fix-pushed",
      "from": ["fixer"],
      "event": "FIX_PUSHED",
      "to": "review"
    },
    {
      "id": "review-approved",
      "from": ["review"],
      "event": "REVIEW_PACKET",
      "packet_type": "REVIEW_PACKET",
      "to": "merge",
      "all": [
        {"path": "packet.ready_for_jiminy", "equals": true},
        {"path": "packet.reviewed_head_sha", "equals_path": "live.pr_head_sha"}
      ]
    },
    {
      "id": "merge-result-recorded",
      "from": ["merge"],
      "event": "JIMINY_PR_RESULT",
      "packet_type": "JIMINY_PR_RESULT",
      "to": "merge",
      "all": [
        {"path": "packet.state", "equals": "MERGED"},
        {"path": "packet.reviewed_head_sha", "equals_path": "persisted.head_sha"},
        {"path": "packet.merge_commit_sha", "non_empty": true}
      ]
    },
    {
      "id": "merge-set-verified",
      "from": ["merge"],
      "event": "MERGES_VERIFIED",
      "to": "integration_verification",
      "all": [
        {"path": "packet.merge_results", "map_keys_equal_path": "ready.expected_pr_urls"},
        {"path": "packet.merge_results", "values_full_sha": true}
      ]
    },
    {
      "id": "integration-passed",
      "from": ["integration_verification"],
      "event": "JIMINY_COMPLETE",
      "packet_type": "JIMINY_COMPLETE",
      "to": "complete",
      "all": [
        {"path": "packet.integration.expected_merges_present", "equals": true},
        {"path": "packet.integration.required_checks_green", "equals": true},
        {"path": "packet.integration.linked_issues_verified", "equals": true},
        {"path": "packet.integration.runtime_ready_for_completion", "equals": true}
      ]
    },
    {
      "id": "integration-failed",
      "from": ["integration_verification"],
      "event": "JIMINY_INTEGRATION_FAILED",
      "packet_type": "JIMINY_INTEGRATION_FAILED",
      "to": "research",
      "set": {"research_mode": "remediation_leaf"}
    },
    {
      "id": "contract-invalidated",
      "from": ["implementation", "review", "fixer", "merge", "integration_verification"],
      "event": "MATERIAL_CONTRACT_CHANGED",
      "to": "research"
    },
    {
      "id": "base-invalidated",
      "from": ["review", "fixer", "merge"],
      "event": "MATERIAL_BASE_CHANGED",
      "to": "implementation"
    },
    {
      "id": "head-invalidated",
      "from": ["review", "fixer", "merge"],
      "event": "PR_HEAD_CHANGED",
      "to": "review",
      "set": {"fixer_pass_invalidated": true}
    },
    {
      "id": "repair-limit-reached",
      "from": ["review", "fixer"],
      "event": "REVIEW_FIX_LIMIT_EXCEEDED",
      "to": "needs_decision"
    },
    {
      "id": "authority-required",
      "from": ["research", "implementation", "review", "fixer", "merge", "integration_verification"],
      "event": "AUTHORITY_REQUIRED",
      "to": "needs_decision"
    },
    {
      "id": "lane-blocked",
      "from": ["research", "implementation", "review", "fixer", "merge", "integration_verification"],
      "event": "FLOW_BLOCKED",
      "to": "blocked"
    },
    {
      "id": "lane-unresponsive",
      "from": ["research", "implementation", "review", "fixer", "merge", "integration_verification"],
      "event": "LANE_UNRESPONSIVE",
      "to": "blocked"
    },
    {
      "id": "restart-budget-exceeded",
      "from": ["research", "implementation", "review", "fixer", "merge", "integration_verification"],
      "event": "RESTART_BUDGET_EXCEEDED",
      "to": "needs_decision"
    },
    {
      "id": "resume",
      "from": ["blocked", "needs_decision"],
      "event": "RESUME_AUTHORIZED",
      "to_path": "resume_node"
    },
    {
      "id": "cancel",
      "from": ["research", "implementation", "review", "fixer", "merge", "integration_verification", "blocked", "needs_decision"],
      "event": "DELIVERY_CANCELLED",
      "to": "cancelled"
    }
  ]
}
