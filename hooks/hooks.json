{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"${CODEX_HOME:-$HOME/.codex}/orchestration-skills/hooks/voice_state.py\" hook",
            "timeout": 15,
            "statusMessage": "Checking voice-task tool authority"
          }
        ]
      }
    ]
  }
}
