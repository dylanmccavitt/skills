{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dylanmccavitt/skills/evaluation/schemas/suite-v2.schema.json",
  "title": "Evaluation Suite Version 2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "suite_id", "suite_version", "fixtures"],
  "properties": {
    "schema_version": {"const": 2},
    "suite_id": {"const": "orchestration-baselines"},
    "suite_version": {"const": 2},
    "fixtures": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fixture_id", "fixture_version", "manifest", "public_manifest_sha256", "public_payload_tree_sha256", "seed_repository_tree_sha256", "grader_contract_sha256"],
        "properties": {
          "fixture_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "fixture_version": {"type": "integer", "enum": [1, 2]},
          "manifest": {"type": "string", "pattern": "^fixtures/[a-z0-9-]+/public/manifest-v[12]\\.json$"},
          "public_manifest_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "public_payload_tree_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "seed_repository_tree_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "grader_contract_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
        }
      }
    }
  }
}
