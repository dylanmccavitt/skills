{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dylanmccavitt/skills/evaluation/schemas/fixture-v1.schema.json",
  "title": "Public evaluation fixture version 1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "fixture_id", "fixture_version", "scenario_kind", "prompt", "acceptance_criteria", "seed_repository", "initial_repository", "grader"],
  "properties": {
    "schema_version": {"const": 1},
    "fixture_id": {"type": "string", "minLength": 1},
    "fixture_version": {"const": 1},
    "scenario_kind": {"enum": ["low_risk_existing_tests", "seeded_review_defects"]},
    "prompt": {"type": "string", "minLength": 1},
    "acceptance_criteria": {"type": "string", "minLength": 1},
    "seed_repository": {"type": "string", "minLength": 1},
    "initial_repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_branch", "initial_ref", "clean_worktree"],
      "properties": {
        "default_branch": {"type": "string", "minLength": 1},
        "initial_ref": {"type": "string", "minLength": 1},
        "clean_worktree": {"const": true}
      }
    },
    "grader": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"const": 1},
        "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    }
  }
}
