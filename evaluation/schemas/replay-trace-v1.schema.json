{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dylanmccavitt/skills/evaluation/schemas/replay-trace-v1.schema.json",
  "title": "Protocol replay trace v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "trace_id",
    "trace_version",
    "suite",
    "fixture",
    "initial_repository_sha",
    "execution",
    "initial_state",
    "events"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "trace_id": {"$ref": "#/$defs/id"},
    "trace_version": {"const": 1},
    "suite": {"$ref": "#/$defs/identity"},
    "fixture": {"$ref": "#/$defs/identity"},
    "initial_repository_sha": {"$ref": "#/$defs/sha"},
    "execution": {"$ref": "#/$defs/execution"},
    "initial_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "data"],
      "properties": {
        "node": {"$ref": "#/$defs/node"},
        "data": {"type": "object"}
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "event", "current_node", "context"],
        "properties": {
          "id": {"$ref": "#/$defs/id"},
          "event": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"},
          "current_node": {"$ref": "#/$defs/node"},
          "context": {"type": "object"},
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "required": ["disposition"],
            "properties": {
              "disposition": {
                "enum": ["accepted", "rejected", "unsupported", "error"]
              },
              "transition_id": {"type": ["string", "null"], "minLength": 1},
              "target_node": {"type": ["string", "null"], "minLength": 1},
              "error_code": {"type": ["string", "null"], "minLength": 1}
            }
          }
        }
      }
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "node": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "content_sha256"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "version": {"const": 1},
        "content_sha256": {"$ref": "#/$defs/digest"}
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "model",
        "reasoning",
        "time_budget_seconds",
        "environment_contract_sha256",
        "trial_id"
      ],
      "properties": {
        "kind": {"const": "protocol-replay"},
        "model": {"const": "non-agent"},
        "reasoning": {"const": "none"},
        "time_budget_seconds": {"type": "integer", "minimum": 1},
        "environment_contract_sha256": {"$ref": "#/$defs/digest"},
        "trial_id": {"$ref": "#/$defs/id"}
      }
    }
  }
}
