{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dylanmccavitt/skills/evaluation/schemas/grader-v1.schema.json",
  "title": "Held-out grader contract version 1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "grader_id", "grader_version", "fixture_id", "fixture_version", "public_fixture_sha256", "checks"],
  "properties": {
    "schema_version": {"const": 1},
    "grader_id": {"type": "string", "minLength": 1},
    "grader_version": {"const": 1},
    "fixture_id": {"type": "string", "minLength": 1},
    "fixture_version": {"const": 1},
    "public_fixture_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "category", "required", "execution", "expected"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "category": {"enum": ["functional_outcome", "contract_fidelity", "seeded_defect_detection"]},
          "required": {"type": "boolean"},
          "execution": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "argv", "timeout_seconds"],
            "properties": {
              "kind": {"const": "process"},
              "argv": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
              "timeout_seconds": {"type": "integer", "minimum": 1}
            }
          },
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "required": ["observation", "value"],
            "properties": {
              "observation": {"type": "string", "minLength": 1},
              "value": {}
            }
          }
        }
      }
    }
  }
}
